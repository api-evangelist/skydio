  "info": {
    "_postman_id": "32f6e9fd-5196-413f-ac6d-e64c6ef235f3",
    "name": "Skydio Cloud API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Skydio Cloud API is an HTTP-based REST API with JSON request and response bodies that lets developers manage Skydio drone fleets programmatically. Endpoints cover vehicles, flights, and markers (incidents), among other resources. Authentication uses API tokens generated in Skydio Cloud (Settings > API Tokens > Generate Token) and sent in the credentials header of every request.\n\nContact Support:\n Name: Skydio Cloud API",
      "type": "text/plain"
    }
  }
